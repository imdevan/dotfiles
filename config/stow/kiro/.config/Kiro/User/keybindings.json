// Place your key bindings in this file to override the defaults
[
  {
    "key": "ctrl+i",
    "command": "composerMode.agent"
  },
  {
    "key": "ctrl+t",
    "command": "-workbench.action.showAllSymbols"
  },
  {
    "key": "ctrl+t",
    "command": "workbench.action.terminal.focus",
    "when": "!terminalFocus"
  },
  {
    "key": "ctrl+t",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "terminalFocus"
  },
  {
    "key": "shift+ctrl+backspace",
    "command": "workbench.action.terminal.kill"
  },
  {
    "key": "ctrl+g",
    "command": "workbench.scm.focus"
  },
{
    "key": "ctrl+k",
    "command": "inlineChat.start",
    "when": "inlineChatHasEditsAgent && inlineChatPossible && !editorReadonly && !editorSimpleInput && activeEditor != 'workbench.editor.notebook' || inlineChatHasNotebookAgent && inlineChatPossible && !editorReadonly && !editorSimpleInput && activeEditor == 'workbench.editor.notebook' || inlineChatHasNotebookInline && inlineChatPossible && !editorReadonly && !editorSimpleInput && activeEditor == 'workbench.editor.notebook' || inlineChatHasProvider && inlineChatPossible && !editorReadonly && !editorSimpleInput && activeEditor != 'workbench.editor.notebook'"
},
{
    "key": "ctrl+shift+l",
    "command": "welcome.newWorkspaceChat"
},
{
    "key": "ctrl+shift+l",
    "command": "kiroAgent.newSession"
}
]
