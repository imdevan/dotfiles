# Empty sketchybar

PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Bar Appearance #####
bar=(
  position=top
  height=32
  blur_radius=40
  color=0x50000000
  # color=0x40000000
  border_color=0x40000000
  border_width=1
)
sketchybar --bar "${bar[@]}"

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
